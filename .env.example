# Optional provider credentials for future non-deterministic model providers.
# The deterministic v1 demo does not require API keys.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
ANTHROPIC_API_KEY=

# Optional trusted remote Knowledge Source adapter credentials.
# Use env var references such as PA_KNOWLEDGE_TOKEN in http_json header_env_refs.
PA_KNOWLEDGE_TOKEN=

# Private Hybrid Knowledge model-serving plane (secret-free internal service origins).
# Keep disabled for the deterministic local/demo path. When enabled, every value is required.
PA_HYBRID_KNOWLEDGE_MODELS_ENABLED=0
PA_KNOWLEDGE_MODEL_SCHEDULER_ENDPOINT=
PA_KNOWLEDGE_MODEL_SCHEDULER_NAMESPACE=
PA_KNOWLEDGE_DOCLING_ENDPOINT=
PA_KNOWLEDGE_PADDLE_ENDPOINT=
PA_KNOWLEDGE_EMBEDDING_ENDPOINT=
PA_KNOWLEDGE_RERANKER_ENDPOINT=
