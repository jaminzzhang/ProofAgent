# Optional provider credentials for future non-deterministic model providers.
# The deterministic v1 demo does not require API keys.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
AZURE_OPENAI_API_KEY=

# PageIndex local service (start with: cd services/pageindex && uvicorn server:app --port 8001)
PAGEINDEX_BASE_URL=http://127.0.0.1:8001
