# Optional provider credentials for future non-deterministic model providers.
# The deterministic v1 demo does not require API keys.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
ANTHROPIC_API_KEY=

# Optional trusted remote Knowledge Source adapter credentials.
# Use env var references such as PA_KNOWLEDGE_TOKEN in http_json header_env_refs.
PA_KNOWLEDGE_TOKEN=

# Private Hybrid Knowledge model-serving plane (secret-free internal service origins).
# Keep disabled for the deterministic local/demo path. When enabled, every value is required.
PA_HYBRID_KNOWLEDGE_MODELS_ENABLED=0
PA_KNOWLEDGE_MODEL_SCHEDULER_ENDPOINT=
PA_KNOWLEDGE_MODEL_SCHEDULER_NAMESPACE=
PA_KNOWLEDGE_MODEL_ALLOWED_HOSTS=
PA_KNOWLEDGE_MODEL_ALLOWED_CIDRS=
PA_KNOWLEDGE_DOCLING_ENDPOINT=
PA_KNOWLEDGE_PADDLE_ENDPOINT=
PA_KNOWLEDGE_EMBEDDING_ENDPOINT=
PA_KNOWLEDGE_RERANKER_ENDPOINT=
PA_KNOWLEDGE_PARSER_REVISION=
PA_KNOWLEDGE_MODEL_DIGESTS=
PA_KNOWLEDGE_PARSER_CONFIGURATION_SHA256=

# Disposable Hybrid Knowledge integration and recovery evidence only.
# Never set these markers for production repositories or buckets.
HYBRID_TEST_POSTGRES_DSN=
HYBRID_TEST_S3_ENDPOINT=
HYBRID_TEST_S3_BUCKET=proof-agent-test
HYBRID_TEST_S3_ACCESS_KEY=
HYBRID_TEST_S3_SECRET_KEY=
HYBRID_TEST_OPENSEARCH_URL=
HYBRID_TEST_DISPOSABLE_MARKER=0
HYBRID_TEST_REPOSITORY_MARKER=
HYBRID_TEST_BUCKET_MARKER=
HYBRID_TEST_SOURCE_ID=
HYBRID_TEST_GENERATION_ID=
PA_KNOWLEDGE_CAPACITY_DRIVER=
PA_KNOWLEDGE_RECOVERY_DRIVER=
PA_KNOWLEDGE_SHADOW_DRIVER=
PA_KNOWLEDGE_ACCEPTANCE_DRIVER=
PA_KNOWLEDGE_ACCEPTANCE_VERIFIER=
PA_KNOWLEDGE_OPERATIONS_PROVIDER=
PA_KNOWLEDGE_RELEASE_AUTHORITY=

# Private production Knowledge evaluation/operations service.
# Driver selectors use `private-http`; the verifier selector uses `hmac-sha256`.
PA_KNOWLEDGE_EVALUATION_ENDPOINT=
PA_KNOWLEDGE_EVALUATION_ALLOWED_HOSTS=
PA_KNOWLEDGE_EVALUATION_ALLOWED_CIDRS=
PA_KNOWLEDGE_EVALUATION_TOKEN=
PA_KNOWLEDGE_EVALUATION_TIMEOUT_SECONDS=30
PA_KNOWLEDGE_ACCEPTANCE_EVALUATOR_IDS=
PA_KNOWLEDGE_ACCEPTANCE_TRUSTED_KEY_ID=
PA_KNOWLEDGE_ACCEPTANCE_HMAC_SECRET=
